# =============================================================================
# IMPORTANT
# =============================================================================
# 1. Copy this file to:  server/.env   (for local backend)
# 2. For Render (production): paste the SAME values in Render Dashboard →
#    Environment. Render does NOT read .env files from your computer!
# 3. Do NOT use 127.0.0.1 on Render — use MongoDB Atlas (mongodb+srv://...)
# =============================================================================

# MongoDB Atlas — get from https://cloud.mongodb.com → Connect → Drivers
# Example (replace USER, PASSWORD, cluster host):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/studyapp?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/studyapp?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string
PORT=5000
CLIENT_URL=https://study-app-liart.vercel.app,http://localhost:3000

# Frontend (Vercel Environment Variables)
VITE_API_URL=https://study-app-1-dyv3.onrender.com
