# Copy to server/.env and fill in MONGO_URI_ATLAS (MongoDB Atlas connection string)

MONGO_URI_ATLAS=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/studyapp?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/studyapp
JWT_SECRET=change-this-to-a-long-random-string
PORT=5000
CLIENT_URL=https://study-app-liart.vercel.app,http://localhost:3000
