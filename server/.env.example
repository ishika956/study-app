# Copy to server/.env and fill in your real MongoDB Atlas connection string.
# Do NOT use mongodb://127.0.0.1 for deployed app — only for local MongoDB if installed.

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/studyapp?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
PORT=5000
CLIENT_URL=https://study-app-liart.vercel.app,http://localhost:3000
